{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    
    // 1. Add the types right here inside compilerOptions!
    "types": ["jest", "node"]
  },
  
  // 2. Include the tests folder (assuming your tests are outside src)
  "include": ["src/**/*", "tests/**/*"],
  
  // 3. Remove "**/*.test.ts" so TypeScript stops ignoring your test files!
  "exclude": ["node_modules"]
}